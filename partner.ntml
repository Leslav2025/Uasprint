<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UA PARTNER - ФРАНШИЗА</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <script src="https://unpkg.com/@tonconnect/ui@latest/dist/tonconnect-ui.min.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-app.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-firestore.js"></script>
    <style>
        body { background: #0b101b; color: white; font-family: 'Segoe UI', sans-serif; padding: 20px; display: flex; flex-direction: column; align-items: center; }
        .card { background: #151b2b; padding: 25px; border-radius: 24px; border: 1px solid #ffd700; width: 100%; max-width: 400px; text-align: center; }
        .info-box { background: rgba(255, 215, 0, 0.1); padding: 15px; border-radius: 15px; margin-bottom: 20px; font-size: 14px; line-height: 1.4; border: 1px solid rgba(255, 215, 0, 0.3); }
        h1 { color: #ffd700; font-size: 20px; text-transform: uppercase; margin-bottom: 15px; }
        label { display: block; text-align: left; font-size: 11px; margin: 10px 0 5px 5px; color: #ffd700; text-transform: uppercase; }
        input, select { width: 100%; padding: 12px; margin-bottom: 10px; border-radius: 10px; border: 1px solid #2a3454; background: #0b101b; color: white; box-sizing: border-box; }
        .btn-pay { background: linear-gradient(90deg, #ffd700, #ff8800); color: black; padding: 16px; width: 100%; border-radius: 12px; font-weight: 900; border: none; cursor: pointer; margin-top: 10px; }
        #link-res { display: none; margin-top: 20px; padding: 15px; background: #1b2e1b; border-radius: 12px; border: 1px dashed #4caf50; word-break: break-all; }
    </style>
</head>
<body>

    <div class="card">
        <h1>СТАНЬ ПАРТНЕРОМ 🚀</h1>
        
        <div class="info-box">
            💰 Отримуй <b>90%</b> від кожної ставки гравців.<br>
            💎 Обирай валюту: <b>TON</b> або <b>USDT</b>.<br>
            ⚙️ Повна автоматизація виплат.
        </div>

        <div id="ton-connect" style="margin-bottom: 20px; display: flex; justify-content: center;"></div>

        <label>Валюта вашого казино:</label>
        <select id="p-asset">
            <option value="TON">TON</option>
            <option value="USDT">USDT</option>
        </select>

        <label>Ваш гаманець для прибутку:</label>
        <input type="text" id="p-wallet" placeholder="UQDqC...">

        <label>Ваш Telegram для підтримки:</label>
        <input type="text" id="p-bot" placeholder="@username">

        <button class="btn-pay" onclick="handleAction()">АКТИВУВАТИ ЗА 1 TON</button>

        <div id="link-res">
            <b style="color: #4caf50;">ФРАНШИЗА АКТИВНА!</b><br>
            <p style="font-size: 12px; margin: 5px 0;">Ваше посилання для залучення гравців:</p>
            <code id="p-link" style="color: #ffd700; font-size: 13px;"></code>
        </div>
    </div>

    <script>
        const tg = window.Telegram.WebApp;
        let user = (tg.initDataUnsafe && tg.initDataUnsafe.user) ? (tg.initDataUnsafe.user.username || tg.initDataUnsafe.user.first_name) : "Guest";

        const tonConnectUI = new TON_CONNECT_UI.TonConnectUI({
            manifestUrl: 'https://leslav2025.github.io/Uasprint/tonconnect-manifest.json',
            buttonRootId: 'ton-connect'
        });

        const firebaseConfig = { 
            apiKey: "AIzaSyAYt_bjoLkBBE6LRTKgvbncm_O-rM_K16o", 
            authDomain: "ualottery.firebaseapp.com", 
            projectId: "ualottery", 
            appId: "1:960757780790:web:568c021958b4ec8f0d8bd6" 
        };
        firebase.initializeApp(firebaseConfig);
        const db = firebase.firestore();

        async function handleAction() {
            const wallet = document.getElementById('p-wallet').value.trim();
            const bot = document.getElementById('p-bot').value.trim().replace('@', '');
            const asset = document.getElementById('p-asset').value;

            if(!wallet || !bot) return alert("Заповніть всі поля!");

            // ПЕРЕВІРКА НА ТЕБЕ (Leslav)
            const isOwner = (user.toLowerCase() === "leslav");

            try {
                if (!isOwner) {
                    if(!tonConnectUI.connected) return alert("Будь ласка, підключіть гаманець зверху!");
                    
                    await tonConnectUI.sendTransaction({
                        validUntil: Math.floor(Date.now() / 1000) + 300,
                        messages: [{ address: "EQBrD-UZ8w2tAyxCNjO8lF4ioTwI-ELiQgF7kclC7gM2UOO_", amount: "1000000000" }]
                    });
                }

                await db.collection('partners').doc(user).set({
                    wallet: wallet, bot: bot, asset: asset, active: true
                });

                const finalLink = `https://t.me/tokenpist_bot?start=${user}`;
                document.getElementById('p-link').innerText = finalLink;
                document.getElementById('link-res').style.display = "block";
                alert(isOwner ? "Адмін-активація успішна!" : "Оплата прийнята! Посилання готове.");

            } catch (e) { alert("Транзакцію не підтверджено."); }
        }
    </script>
</body>
</html>
