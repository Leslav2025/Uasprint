<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UA PARTNER - ФРАНШИЗА</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <script src="https://unpkg.com/@tonconnect/ui@latest/dist/tonconnect-ui.min.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-app.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-firestore.js"></script>
    <style>
        body { background: #0b101b; color: white; font-family: 'Segoe UI', sans-serif; padding: 20px; text-align: center; }
        .card { background: #151b2b; padding: 25px; border-radius: 20px; border: 1px solid #ffd700; max-width: 400px; margin: auto; }
        h1 { color: #ffd700; font-size: 22px; }
        input { width: 100%; padding: 12px; margin: 10px 0; border-radius: 10px; border: 1px solid #2a3454; background: #0b101b; color: white; box-sizing: border-box; }
        .btn-buy { background: linear-gradient(90deg, #ffd700, #ff8800); color: black; padding: 15px; width: 100%; border-radius: 12px; font-weight: bold; border: none; cursor: pointer; }
        #partner-link-box { display: none; margin-top: 20px; padding: 15px; background: #000; border-radius: 10px; word-break: break-all; color: #4caf50; border: 1px dashed #4caf50; }
    </style>
</head>
<body>
    <div class="card">
        <h1>СТАНЬ ВЛАСНИКОМ КАЗИНО</h1>
        <p style="font-size: 13px; opacity: 0.8;">Активуй франшизу за 1 TON та отримуй 90% від усіх ставок твоїх гравців автоматично.</p>
        
        <div id="ton-connect" style="margin-bottom: 20px;"></div>

        <input type="text" id="partner-wallet" placeholder="Твій TON Гаманець для виплат">
        <input type="text" id="partner-bot" placeholder="Юзернейм твого бота (напр. tokenpist_bot)">
        
        <button class="btn-buy" id="activate-btn" onclick="activatePartner()">АКТИВУВАТИ ЗА 1 TON</button>

        <div id="partner-link-box">
            <b>Твоє посилання для реклами:</b><br>
            <span id="final-link"></span>
        </div>
    </div>

    <script>
        const tg = window.Telegram.WebApp;
        let userName = (tg.initDataUnsafe && tg.initDataUnsafe.user) ? (tg.initDataUnsafe.user.username || tg.initDataUnsafe.user.first_name) : "User";

        const tonConnectUI = new TON_CONNECT_UI.TonConnectUI({
            manifestUrl: 'https://leslav2025.github.io/Uasprint/tonconnect-manifest.json',
            buttonRootId: 'ton-connect'
        });

        const firebaseConfig = { /* Твій конфиг */ };
        firebase.initializeApp(firebaseConfig);
        const db = firebase.firestore();

        async function activatePartner() {
            const wallet = document.getElementById('partner-wallet').value;
            const bot = document.getElementById('partner-bot').value.replace('@', '');

            if(!wallet || !bot) return alert("Заповніть всі поля!");

            try {
                // 1. Оплата тобі 1 TON
                await tonConnectUI.sendTransaction({
                    validUntil: Math.floor(Date.now() / 1000) + 300,
                    messages: [{ address: "ТВІЙ_ГАМАНЕЦЬ", amount: "1000000000" }]
                });

                // 2. Збереження в базу
                await db.collection('partners').doc(userName).set({
                    wallet: wallet,
                    supportBot: bot,
                    active: true
                });

                // 3. Видача посилання
                const link = `https://t.me/ТВІЙ_ГОЛОВНИЙ_БОТ?start=${userName}`;
                document.getElementById('final-link').innerText = link;
                document.getElementById('partner-link-box').style.display = "block";
                document.getElementById('activate-btn').style.display = "none";
                
                alert("Вітаємо! Франшиза активована.");
            } catch (e) { console.error(e); }
        }
    </script>
</body>
</html>
