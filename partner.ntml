<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UA PARTNER - ПАНЕЛЬ</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <script src="https://unpkg.com/@tonconnect/ui@latest/dist/tonconnect-ui.min.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-app.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.0/firebase-firestore.js"></script>
    <style>
        body { background: #0b101b; color: white; font-family: 'Segoe UI', sans-serif; padding: 20px; display: flex; justify-content: center; }
        .card { background: #151b2b; padding: 30px; border-radius: 24px; border: 1px solid #ffd700; width: 100%; max-width: 400px; text-align: center; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        h1 { color: #ffd700; font-size: 22px; text-transform: uppercase; margin-bottom: 20px; }
        label { display: block; text-align: left; font-size: 12px; margin: 10px 0 5px 5px; color: #ffd700; opacity: 0.8; }
        input, select { width: 100%; padding: 14px; margin-bottom: 15px; border-radius: 12px; border: 1px solid #2a3454; background: #0b101b; color: white; box-sizing: border-box; outline: none; }
        .btn-activate { background: linear-gradient(90deg, #ffd700, #ff8800); color: black; padding: 18px; width: 100%; border-radius: 16px; font-weight: 900; border: none; cursor: pointer; text-transform: uppercase; }
        #link-section { display: none; margin-top: 20px; padding: 15px; background: rgba(76, 175, 80, 0.1); border-radius: 12px; border: 1px dashed #4caf50; word-break: break-all; }
    </style>
</head>
<body>
    <div class="card">
        <h1>ВЛАСНЕ КАЗИНО 🚀</h1>
        <div id="ton-connect" style="margin-bottom: 20px; display: flex; justify-content: center;"></div>

        <label>ВАЛЮТА КАЗИНО:</label>
        <select id="partner-asset">
            <option value="TON">TON (Нативна)</option>
            <option value="USDT">USDT (Tether)</option>
        </select>

        <label>ВАШ ГАМАНЕЦЬ (ДЛЯ ПРИБУТКУ 90%):</label>
        <input type="text" id="partner-wallet" placeholder="UQDqC...">

        <label>ВАШ БОТ ПІДТРИМКИ (@username):</label>
        <input type="text" id="partner-bot" placeholder="напр. tokenpist_bot">

        <button class="btn-activate" id="activate-btn" onclick="activatePartner()">АКТИВУВАТИ ТА ОТРИМАТИ ЛІНК</button>

        <div id="link-section">
            <b style="color: #4caf50;">✅ ПАРТНЕРСТВО АКТИВОВАНЕ!</b><br>
            <p style="font-size: 12px;">Ваше реферальне посилання:</p>
            <span id="final-link" style="color: #4caf50; font-size: 13px; font-weight: bold;"></span>
        </div>
    </div>

    <script>
        const tg = window.Telegram.WebApp;
        let userName = (tg.initDataUnsafe && tg.initDataUnsafe.user) ? (tg.initDataUnsafe.user.username || tg.initDataUnsafe.user.first_name) : "Guest";

        const tonConnectUI = new TON_CONNECT_UI.TonConnectUI({
            manifestUrl: 'https://leslav2025.github.io/Uasprint/tonconnect-manifest.json',
            buttonRootId: 'ton-connect'
        });

        const firebaseConfig = { 
            apiKey: "AIzaSyAYt_bjoLkBBE6LRTKgvbncm_O-rM_K16o", 
            authDomain: "ualottery.firebaseapp.com", 
            projectId: "ualottery", 
            appId: "1:960757780790:web:568c021958b4ec8f0d8bd6" 
        };
        if (!firebase.apps.length) firebase.initializeApp(firebaseConfig);
        const db = firebase.firestore();

        async function activatePartner() {
            const wallet = document.getElementById('partner-wallet').value.trim();
            const bot = document.getElementById('partner-bot').value.trim().replace('@', '');
            const asset = document.getElementById('partner-asset').value;

            // ПЕРЕВІРКА НА ТЕБЕ (Адмін)
            const isAdmin = (userName.toLowerCase() === "leslav"); 

            if(!wallet || !bot) return alert("Заповніть всі поля!");

            try {
                if (!isAdmin) {
                    if(!tonConnectUI.connected) return alert("Спочатку підключіть гаманець!");
                    
                    await tonConnectUI.sendTransaction({
                        validUntil: Math.floor(Date.now() / 1000) + 300,
                        messages: [{ 
                            address: "EQBrD-UZ8w2tAyxCNjO8lF4ioTwI-ELiQgF7kclC7gM2UOO_", 
                            amount: "1000000000" 
                        }]
                    });
                }

                await db.collection('partners').doc(userName).set({
                    wallet: wallet,
                    supportBot: bot,
                    asset: asset,
                    active: true,
                    timestamp: firebase.firestore.FieldValue.serverTimestamp()
                });

                // ТУТ ПЕРЕВІР, ЩОБ ЮЗЕРНЕЙМ БОТА БУВ ПРАВИЛЬНИЙ
                const link = `https://t.me/tokenpist_bot?start=${userName}`;
                document.getElementById('final-link').innerText = link;
                document.getElementById('link-section').style.display = "block";
                document.getElementById('activate-btn').style.display = "none";
                
                alert(isAdmin ? "Привіт, Leslav! Франшиза активована без оплати." : "Вітаємо! Тепер ви партнер.");

            } catch (e) {
                console.error(e);
                alert("Помилка активації.");
            }
        }
    </script>
</body>
</html>
